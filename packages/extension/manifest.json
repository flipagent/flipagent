{
	"manifest_version": 3,
	"name": "flipagent",
	"version": "0.1.1",
	"description": "flipagent evaluates eBay listings as flip opportunities. This extension lets the AI act on them in your own Chrome.",
	"icons": {
		"16": "icons/icon-16.png",
		"32": "icons/icon-32.png",
		"48": "icons/icon-48.png",
		"128": "icons/icon-128.png"
	},
	"action": {
		"default_title": "flipagent",
		"default_popup": "popup.html",
		"default_icon": {
			"16": "icons/icon-16.png",
			"32": "icons/icon-32.png"
		}
	},
	"side_panel": {
		"default_path": "sidepanel.html"
	},
	"background": {
		"service_worker": "background.js",
		"type": "module"
	},
	"content_scripts": [
		{
			"matches": [
				"https://www.ebay.com/*",
				"https://*.ebay.com/*",
				"https://app.planetexpress.com/*",
				"https://www.planetexpress.com/*"
			],
			"js": ["content.js"],
			"run_at": "document_idle"
		},
		{
			"matches": [
				"https://flipagent.dev/*",
				"https://*.flipagent.dev/*"
			],
			"js": ["presence.js"],
			"run_at": "document_start"
		}
	],
	"permissions": ["storage", "alarms", "tabs", "scripting", "sidePanel", "cookies", "notifications"],
	"host_permissions": [
		"https://www.ebay.com/*",
		"https://*.ebay.com/*",
		"https://app.planetexpress.com/*",
		"https://www.planetexpress.com/*",
		"https://*.flipagent.dev/*"
	],
	"externally_connectable": {
		"matches": [
			"https://flipagent.dev/*",
			"https://*.flipagent.dev/*"
		]
	}
}
