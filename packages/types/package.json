{
	"name": "@flipagent/types",
	"version": "0.0.1",
	"description": "TypeBox schemas for flipagent — `/v1/*` API surface (evaluate, discover, ship, …) at the root, eBay-shape responses (Browse, Marketplace Insights, Sell Inventory, Sell Fulfillment) under `/ebay/{buy,sell}` subpaths.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./ebay": {
			"types": "./dist/ebay/index.d.ts",
			"import": "./dist/ebay/index.js"
		},
		"./ebay/buy": {
			"types": "./dist/ebay/buy.d.ts",
			"import": "./dist/ebay/buy.js"
		},
		"./ebay/sell": {
			"types": "./dist/ebay/sell.d.ts",
			"import": "./dist/ebay/sell.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist *.tsbuildinfo",
		"build": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest --run --passWithNoTests"
	},
	"dependencies": {
		"@sinclair/typebox": "^0.34.41"
	},
	"devDependencies": {
		"@types/node": "^22.10.5",
		"shx": "^0.4.0",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"keywords": [
		"flipagent",
		"typebox",
		"types",
		"ebay"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/flipagent/flipagent.git",
		"directory": "packages/types"
	},
	"publishConfig": {
		"access": "public"
	}
}
