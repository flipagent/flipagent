{
	"name": "@flipagent/sdk",
	"version": "0.0.2",
	"description": "Official SDK for api.flipagent.dev — the unified reseller API. Typed namespaces for marketplace data (items, categories, products), my-side writes (listings, purchases, sales), money (payouts, transactions), disputes / policies / forwarder, plus flipagent intelligence (evaluate, ship, expenses) and ops (webhooks, capabilities). One client, one API key.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist *.tsbuildinfo",
		"build": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
		"test": "vitest --run"
	},
	"dependencies": {
		"@flipagent/types": "^0.0.1"
	},
	"devDependencies": {
		"@types/node": "^22.10.5",
		"shx": "^0.4.0",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"keywords": [
		"ebay",
		"flipagent",
		"sdk",
		"client"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/flipagent/flipagent.git",
		"directory": "packages/sdk"
	},
	"publishConfig": {
		"access": "public"
	}
}
