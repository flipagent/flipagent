{
	"name": "flipagent-cli",
	"version": "0.0.1",
	"description": "flipagent CLI — log in, drive the API from your shell (search / sold / evaluate / discover / ship), and one-command-set-up the flipagent MCP server for Claude Desktop / Cursor / Cline / Zed / Windsurf. Buy-side execution (/v1/buy/order/*) lives in the flipagent Chrome extension. Zero runtime deps.",
	"type": "module",
	"main": "./dist/index.js",
	"bin": {
		"flipagent-cli": "./dist/index.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"clean": "shx rm -rf dist *.tsbuildinfo",
		"build": "tsc -p tsconfig.build.json && shx chmod +x dist/index.js",
		"dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput"
	},
	"devDependencies": {
		"@types/node": "^22.10.5",
		"shx": "^0.4.0",
		"typescript": "^5.9.2"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"keywords": [
		"flipagent",
		"mcp",
		"cli",
		"agent",
		"claude",
		"cursor",
		"ebay",
		"reselling"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/flipagent/flipagent.git",
		"directory": "packages/cli"
	},
	"publishConfig": {
		"access": "public"
	}
}
