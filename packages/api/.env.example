# Postgres connection string. Local dev with the bundled docker-compose:
DATABASE_URL=postgres://flipagent:flipagent@localhost:55432/flipagent

# HTTP port the api binds to.
PORT=4000

# "development" relaxes some checks; "production" enables strict mode.
NODE_ENV=development

# Managed-scraping vendor for `EBAY_*_SOURCE=scrape`. The vendor owns
# the anti-bot dance; we just POST a URL and get rendered HTML.
# flipagent does not ship its own residential-proxy + UA-rotation
# path on purpose — that's ToS-grey and belongs at vendors whose
# business is exactly that. Self-hosters who don't want this
# dependency should point `EBAY_*_SOURCE` at `bridge` or `rest`.
#
# Today only `oxylabs` is wired (Web Scraper API).
# SCRAPER_API_VENDOR=oxylabs
# SCRAPER_API_USERNAME=
# SCRAPER_API_PASSWORD=

# Stripe billing. All five vars required to enable /v1/billing/* — leave any
# unset and those routes return 503 billing_not_configured.
# Hobby = $19/mo, Standard = $99/mo, Growth = $399/mo.
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_HOBBY=price_xxx
# STRIPE_PRICE_STANDARD=price_xxx
# STRIPE_PRICE_GROWTH=price_xxx

# eBay OAuth. Required for /v1/connect/ebay + every sell-side route
# (/v1/listings, /v1/sales, /v1/payouts, /v1/transactions, /v1/policies,
# /v1/disputes, …) and the REST transport of /v1/purchases. Leave unset
# and those routes return 503 not_configured.
# Register an "Application keyset" + RuName at https://developer.ebay.com/.
# Sandbox: swap api.ebay.com → api.sandbox.ebay.com and auth.ebay.com → auth.sandbox.ebay.com.
#
# RuName redirect URL: in the eBay developer portal, the RuName is configured
# with an HTTPS redirect URL. eBay redirects the consenting user there with
# `?code=`. flipagent's matching route is /v1/connect/ebay/callback, so the
# RuName redirect URL must point at that path on a publicly reachable host.
#   - Production: https://api.flipagent.dev/v1/connect/ebay/callback
#   - Local dev:  https://dev.flipagent.dev/v1/connect/ebay/callback
#                 (run `npm run tunnel` from packages/api/ — sets up a
#                  Cloudflare tunnel from dev.flipagent.dev → localhost:$PORT
#                  so eBay can reach your local API)
# EBAY_CLIENT_ID=YourApp-PRD-...
# EBAY_CLIENT_SECRET=PRD-...
# EBAY_RU_NAME=Your_App_Name-RuName    # value from eBay's "User Tokens" tab, NOT a URL
# EBAY_BASE_URL=https://api.ebay.com
# EBAY_AUTH_URL=https://auth.ebay.com
# EBAY_SCOPES=https://api.ebay.com/oauth/api_scope https://api.ebay.com/oauth/api_scope/sell.inventory ...

# Set to 1 ONLY after eBay approves flipagent's tenant for the Buy Order API
# (Limited Release). Until then /v1/purchases REST transport returns 501;
# bridge transport still works.
# EBAY_ORDER_API_APPROVED=0

# eBay Trading API Platform Notifications (legacy XML push). When all four
# below are set, /v1/notifications/ebay/* light up. eBay POSTs SOAP/XML to
# EBAY_NOTIFY_URL whenever a subscribed event happens (ItemSold, etc.).
# DevID is the third value on the same Application Keys page as
# CLIENT_ID/SECRET. NOTIFY_URL must be HTTPS-reachable from eBay servers
# (a tunnel like cloudflared works for dev).
# EBAY_DEV_ID=00000000-0000-0000-0000-000000000000
# EBAY_NOTIFY_URL=https://dev.flipagent.dev/v1/notifications/ebay/inbound

# Per-route source toggles. Each picks how /v1/items/* resolves:
#   rest    — eBay REST (Browse for active, Marketplace Insights for sold).
#             Requires EBAY_CLIENT_ID/SECRET. Sold also requires
#             EBAY_INSIGHTS_APPROVED=1 (Limited Release per-tenant approval).
#   scrape  — managed scraper vendor (Oxylabs Web Scraper API). Always
#             available when SCRAPER_API_USERNAME/PASSWORD are set.
#   bridge  — browser-extension bridge (the user's own session). Available
#             when the api key has a paired Chrome extension.
# Auto behavior (no env override): rest when its prerequisites are met,
# otherwise scrape. So unconfigured-eBay self-hosters and Insights-unapproved
# tenants both transparently fall to scrape — no env tweaking required.
# EBAY_LISTINGS_SOURCE=rest
# EBAY_DETAIL_SOURCE=rest
# EBAY_SOLD_SOURCE=rest

# Set to 1 ONLY after eBay approves the tenant for the Marketplace Insights
# program (sold-listing history via REST). With this flag,
# /v1/items/search?status=sold hits the Insights REST endpoint using the
# app token. Without it, the route falls back to scraping. Apply at
# developer.ebay.com → Marketplace Insights.
# EBAY_INSIGHTS_APPROVED=0

# Set to 1 ONLY after eBay approves the tenant for the Commerce Catalog
# API. With this flag, /v1/products/{epid} hits Catalog REST. Without it,
# the route falls back to scraping /p/{epid} + a representative listing
# and emits the same Product shape. eBay denies most apps; default off is
# normal.
# EBAY_CATALOG_APPROVED=0

# Better-Auth + GitHub OAuth. Required for the dashboard sign-in flow.
# When unset, /api/auth/* and /v1/me/* return 503 not_configured.
#   BETTER_AUTH_SECRET   secret for signing session cookies (openssl rand -base64 32)
#   APP_URL              dashboard origin (the docs site) — used for trusted-origin
#                        + post-checkout success URL
#   BETTER_AUTH_URL      this api's external URL — what GitHub redirects to;
#                        callback URL on the GitHub OAuth app must be
#                        {BETTER_AUTH_URL}/api/auth/callback/github
#   GITHUB_CLIENT_ID/SECRET   from https://github.com/settings/developers
# APP_URL=http://localhost:4321
# BETTER_AUTH_URL=http://localhost:4000
# BETTER_AUTH_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Symmetric key (32 bytes, base64) used to encrypt issued API key plaintext
# at rest. Lets the dashboard's "reveal" button show the full key on demand.
# Required in production. In development, omit it and a fallback is derived
# from BETTER_AUTH_SECRET so local setups don't break.
# Generate: `openssl rand -base64 32`
# KEYS_ENCRYPTION_KEY=

# Symmetric key (32 bytes, base64) for the secrets envelope — wraps eBay
# OAuth refresh tokens and webhook HMAC secrets at rest with AES-256-GCM.
# Required in production; the api throws on boot without it. In dev the
# helper falls back to a deterministic key derived from BETTER_AUTH_SECRET.
# Kept separate from KEYS_ENCRYPTION_KEY so the API-key blast radius
# stays smaller. Generate: `openssl rand -base64 32`
# SECRETS_ENCRYPTION_KEY=

# Google OAuth (optional). When set, "Continue with Google" lights up on /signup.
# Authorized redirect URI on the Google OAuth client must be
# {BETTER_AUTH_URL}/api/auth/callback/google
# Create at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email sender (Resend). Required for password reset (and future email
# verification). Get an API key at https://resend.com/api-keys.
# `EMAIL_FROM` must be a verified sender on your Resend domain.
# RESEND_API_KEY=
# EMAIL_FROM=flipagent <noreply@flipagent.dev>

# LLM provider for the same-product matcher used internally by
# /v1/evaluate. Provider-agnostic — pick one of Anthropic / OpenAI /
# Google. `LLM_PROVIDER` explicitly selects, otherwise the first key
# set wins (anthropic → openai → google). Without any key, the
# composite endpoint falls back to the unfiltered sold + active pools.
# Every other route works fine without an LLM.
# LLM_PROVIDER=anthropic
#
# Anthropic Claude — https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5
#
# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.4-mini
#
# Google Gemini — https://aistudio.google.com/apikey
# GOOGLE_API_KEY=...
# GOOGLE_MODEL=gemini-2.5-flash
#
# Per-process LLM concurrency cap. matchPool fans out per verify chunk
# inside an evaluate run; without a cap they all hit the provider at
# once and the slowest queue at provider side. Set to your provider
# tier's safe in-flight limit. Default 8. Anthropic tier 1: ~4.
# Tier 2+: 8-16.
# LLM_MAX_CONCURRENT=8

# Comma-separated list of email addresses that auto-promote to `role=admin`
# on sign-up + on every session resolution. Admins can hit /v1/admin/* and
# the /admin dashboard page (grant credits, change tiers, force-revoke keys,
# inspect any user). Empty list = no admins (closed by default).
# ADMIN_EMAILS=you@flipagent.dev,ops@flipagent.dev

# Per-listing observation archive (hosted-only feature). When `1`, every
# `/v1/items/*` response writes a row to `listing_observations` so
# flipagent can build long-tail historical sold-listing depth, matcher
# fingerprinting, and cross-user seller reputation across hosted users.
# Self-hosters typically leave this off (default). ToS-safe: itemWebUrl +
# image-CDN URL only — no binary mirroring, takedown channel honoured.
# OBSERVATION_ENABLED=0

# ----------------------------- worker process -----------------------------
# Tuning for `node dist/worker.js` (the second Container App that runs
# compute_jobs). Defaults are sane for prod; override only when measured.

# Lease deadline per claim. Worker heartbeats every WORKER_HEARTBEAT_MS
# to keep this in the future; if it falls in the past while the row is
# `running`, the recovery sweep requeues (or fails after MAX_ATTEMPTS).
# Default 5min — long enough to absorb a 30s-LLM step + GC pauses.
# WORKER_LEASE_MS=300000

# How often the worker calls renewLease while a job is in flight. Pick
# 5-10× shorter than WORKER_LEASE_MS so a missed heartbeat (transient
# DB blip) doesn't lose the lease.
# WORKER_HEARTBEAT_MS=30000

# After this many lease expirations, the recovery sweep gives up and
# transitions the row to `failed` with code `worker_lease_expired`.
# WORKER_MAX_ATTEMPTS=3

# Idle poll interval — when the queue is empty, the worker sleeps this
# long between claim attempts. Lower = faster pickup, more DB reads.
# WORKER_POLL_INTERVAL_MS=1000

# Recovery sweep interval — how often the worker scans for expired
# leases and requeues / fails them. Boot also runs one sweep before
# the main loop starts.
# WORKER_RECOVERY_INTERVAL_MS=60000

# SIGTERM grace window — how long the worker waits for the in-flight
# job to finish before forcibly releasing its lease and exiting.
# Match Container Apps' graceful-termination policy (default 30s).
# WORKER_SHUTDOWN_GRACE_MS=30000

# Image hosting (Azure Blob Storage; Azurite for local dev) ============
# Connection string for the Blob Storage account that backs `/v1/media`
# image uploads. Without this, image uploads return 503 and callers can
# fall back to externally-hosted image URLs (any HTTPS URL works in a
# listing's `imageUrls[]`).
#
# Local dev (docker-compose pulls in Azurite — wired automatically):
# BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
#
# Production (Azure Blob Storage account, Terraform-managed):
# BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account>;AccountKey=<key>;EndpointSuffix=core.windows.net
#
# Container name. Default = "media". Auto-created on first upload with
# anonymous-blob (read-only) public access so eBay can fetch.
# BLOB_CONTAINER=media

# /v1/bridge/poll longpoll window — how long the route holds the
# connection open while waiting for a new bridge job. Lower = the
# Chrome extension reconnects more often but picks up new jobs
# sooner; higher = fewer reconnects, slightly delayed pickup on idle
# queues. Default 25000 stays under typical edge-proxy idle timeouts
# (Cloudflare 100s, AWS ALB 60s).
# BRIDGE_POLL_WINDOW_MS=25000
