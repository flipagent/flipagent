# Postgres connection string. Local dev with the bundled docker-compose:
DATABASE_URL=postgres://flipagent:flipagent@localhost:55432/flipagent

# HTTP port the api binds to.
PORT=4000

# "development" relaxes some checks; "production" enables strict mode.
NODE_ENV=development

# Managed-scraping vendor for `EBAY_*_SOURCE=scrape`. The vendor owns
# the anti-bot dance; we just POST a URL and get rendered HTML.
# flipagent does not ship its own residential-proxy + UA-rotation
# path on purpose — that's ToS-grey and belongs at vendors whose
# business is exactly that. Self-hosters who don't want this
# dependency should point `EBAY_*_SOURCE` at `bridge` or `rest`.
#
# Today only `oxylabs` is wired (Web Scraper API).
# SCRAPER_API_VENDOR=oxylabs
# SCRAPER_API_USERNAME=
# SCRAPER_API_PASSWORD=

# Stripe billing. Leave unset to disable /v1/billing/* routes (they 503).
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_HOBBY=price_xxx
# STRIPE_PRICE_PRO=price_xxx

# eBay OAuth. Required for /v1/connect/ebay + every /sell/* and /buy/order/v1/*
# passthrough. Leave unset and those routes return 503 not_configured.
# Register an "Application keyset" + RuName at https://developer.ebay.com/.
# Sandbox: swap api.ebay.com → api.sandbox.ebay.com and auth.ebay.com → auth.sandbox.ebay.com.
# EBAY_CLIENT_ID=YourApp-PRD-...
# EBAY_CLIENT_SECRET=PRD-...
# EBAY_RU_NAME=Your_App_Name-RuName    # value from eBay's "User Tokens" tab, NOT a URL
# EBAY_BASE_URL=https://api.ebay.com
# EBAY_AUTH_URL=https://auth.ebay.com
# EBAY_SCOPES=https://api.ebay.com/oauth/api_scope https://api.ebay.com/oauth/api_scope/sell.inventory ...

# Set to 1 ONLY after eBay approves flipagent's tenant for the Buy Order API
# (Limited Release). Until then /buy/order/v1/* routes return 501.
# EBAY_ORDER_API_APPROVED=0

# eBay Trading API Platform Notifications (legacy XML push). When all four
# below are set, /v1/notifications/ebay/* light up. eBay POSTs SOAP/XML to
# EBAY_NOTIFY_URL whenever a subscribed event happens (ItemSold, etc.).
# DevID is the third value on the same Application Keys page as
# CLIENT_ID/SECRET. NOTIFY_URL must be HTTPS-reachable from eBay servers
# (a tunnel like cloudflared works for dev).
# EBAY_DEV_ID=00000000-0000-0000-0000-000000000000
# EBAY_NOTIFY_URL=https://dev.flipagent.dev/v1/notifications/ebay/inbound

# Set to 1 ONLY after eBay approves the tenant for the Marketplace Insights
# program (sold-listing history via REST). With this flag, /v1/sold/* hits
# the Insights REST endpoint using the app token. Without it, /v1/sold/*
# falls back to scraping. Apply at developer.ebay.com → Marketplace Insights.
# EBAY_INSIGHTS_APPROVED=0

# Better-Auth + GitHub OAuth. Required for the dashboard sign-in flow.
# When unset, /api/auth/* and /v1/me/* return 503 not_configured.
#   BETTER_AUTH_SECRET   secret for signing session cookies (openssl rand -base64 32)
#   APP_URL              dashboard origin (the docs site) — used for trusted-origin
#                        + post-checkout success URL
#   BETTER_AUTH_URL      this api's external URL — what GitHub redirects to;
#                        callback URL on the GitHub OAuth app must be
#                        {BETTER_AUTH_URL}/api/auth/callback/github
#   GITHUB_CLIENT_ID/SECRET   from https://github.com/settings/developers
# APP_URL=http://localhost:4321
# BETTER_AUTH_URL=http://localhost:4000
# BETTER_AUTH_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google OAuth (optional). When set, "Continue with Google" lights up on /signup.
# Authorized redirect URI on the Google OAuth client must be
# {BETTER_AUTH_URL}/api/auth/callback/google
# Create at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Email sender (Resend). Required for password reset (and future email
# verification). Get an API key at https://resend.com/api-keys.
# `EMAIL_FROM` must be a verified sender on your Resend domain.
# RESEND_API_KEY=
# EMAIL_FROM=flipagent <noreply@flipagent.dev>
