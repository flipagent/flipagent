{
	"name": "@flipagent/api",
	"version": "0.0.1",
	"private": true,
	"license": "FSL-1.1-ALv2",
	"description": "flipagent backend — Hono + Drizzle + Postgres. Unified API surface for the online reselling cycle (listings, deals, orders, fulfillment, finance) with marketplace adapters underneath.",
	"type": "module",
	"main": "./dist/server.js",
	"types": "./dist/server.d.ts",
	"bin": {
		"flipagent-api": "./dist/server.js"
	},
	"files": [
		"dist",
		"drizzle",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"clean": "shx rm -rf dist *.tsbuildinfo",
		"build": "tsc -p tsconfig.build.json && shx chmod +x dist/server.js",
		"dev": "tsx watch src/server.ts",
		"dev:tunnel": "concurrently -n api,tunnel -c green,blue --hide '' \"tsx watch src/server.ts\" \"bash scripts/dev-tunnel.sh\"",
		"start": "node dist/server.js",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "tsx src/db/migrate.ts",
		"issue-key": "tsx src/scripts/issue-key.ts",
		"fit-beta": "tsx src/scripts/fit-beta.ts",
		"prefetch-taxonomy": "tsx src/scripts/prefetch-taxonomy.ts",
		"gen:spec": "DATABASE_URL=postgres://spec-gen:noop@nowhere/none tsx src/scripts/dump-spec.ts",
		"tunnel": "bash scripts/dev-tunnel.sh",
		"test": "vitest --run"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.91.1",
		"@flipagent/ebay-scraper": "*",
		"@flipagent/types": "*",
		"@google/genai": "^1.50.1",
		"@hono/node-server": "^1.13.0",
		"@hono/typebox-validator": "^0.3.0",
		"@sinclair/typebox": "^0.34.41",
		"better-auth": "^1.6.9",
		"dotenv": "^16.4.5",
		"drizzle-orm": "^0.45.2",
		"fast-xml-parser": "^5.7.2",
		"fetch-retry": "^6.0.0",
		"hono": "^4.6.0",
		"hono-openapi": "^0.4.8",
		"jsdom": "^25.0.1",
		"openai": "^6.35.0",
		"postgres": "^3.4.5",
		"resend": "^6.12.2",
		"stripe": "^17.0.0",
		"yaml": "^2.6.1"
	},
	"devDependencies": {
		"@types/jsdom": "^21.1.7",
		"@types/node": "^22.10.5",
		"drizzle-kit": "^0.31.10",
		"shx": "^0.4.0",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2",
		"vitest": "^3.2.4"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/flipagent/flipagent.git",
		"directory": "packages/api"
	}
}
