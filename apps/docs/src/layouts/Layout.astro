---
import UserMenu from "../components/UserMenu.tsx";
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
	/** Path-relative or absolute. Defaults to current URL resolved against Astro.site. */
	canonical?: string;
	/** When true, emits <meta name="robots" content="noindex,nofollow">. */
	noindex?: boolean;
	/** Absolute or path-relative og:image. Defaults to /og.png. */
	ogImage?: string;
}

const {
	title,
	description = "The full eBay reselling cycle as one API — sourcing, evaluation, buying, listing, fulfillment, finance. Connect via MCP, REST, or the TypeScript SDK.",
	canonical,
	noindex = false,
	ogImage = "/og.png",
} = Astro.props;
const path = Astro.url.pathname;

// Astro.site is set in astro.config.mjs. Resolving the canonical against it
// keeps the URL stable regardless of preview / tunnel hosts at build time.
const siteOrigin = Astro.site ?? new URL("https://flipagent.dev");
const canonicalUrl = new URL(canonical ?? Astro.url.pathname, siteOrigin).toString();
const ogImageUrl = new URL(ogImage, siteOrigin).toString();

// JSON-LD schema graph. Emitted only on the home page so the
// Organization+WebSite entities aren't duplicated across every doc page.
const isHome = path === "/" || path === "";
const jsonLd = isHome
	? {
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "Organization",
					"@id": "https://flipagent.dev/#org",
					name: "flipagent",
					url: "https://flipagent.dev/",
					logo: "https://flipagent.dev/logo.png",
					sameAs: [
						"https://github.com/flipagent/flipagent",
						"https://x.com/flipagent_dev",
					],
				},
				{
					"@type": "WebSite",
					"@id": "https://flipagent.dev/#site",
					url: "https://flipagent.dev/",
					name: "flipagent",
					description:
						"The full eBay reselling cycle as one API — sourcing, evaluation, buying, listing, fulfillment, finance.",
					publisher: { "@id": "https://flipagent.dev/#org" },
				},
				{
					"@type": "SoftwareApplication",
					name: "flipagent",
					applicationCategory: "DeveloperApplication",
					operatingSystem: "Cross-platform",
					description:
						"AI-agent-native API for end-to-end eBay reselling. MCP, REST, and TypeScript SDK.",
					offers: {
						"@type": "Offer",
						price: "0",
						priceCurrency: "USD",
					},
				},
			],
		}
	: null;

// GitHub star count. Build-time fetch is just an SSR baseline — Cloudflare
// Pages builds run on shared IPs that easily hit GitHub's 60/hr unauthenticated
// rate limit, returning 403 and silently zeroing the count until the next deploy.
// The real value gets hydrated client-side from the visitor's own IP (see the
// inline script below the header), which has its own quota and stays fresh
// without redeploying.
//
// `stars === null` means "couldn't fetch" — we render the icon without a number
// so visitors don't briefly see "0" before the JS lands.
const stars: number | null = await fetch(
	"https://api.github.com/repos/flipagent/flipagent",
	{ headers: { Accept: "application/vnd.github+json" } },
)
	.then((r) => (r.ok ? r.json() : null))
	.then((d: { stargazers_count?: number } | null) =>
		typeof d?.stargazers_count === "number" ? d.stargazers_count : null,
	)
	.catch(() => null);
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		{noindex && <meta name="robots" content="noindex,nofollow" />}
		<meta name="theme-color" content="#0a0a0a" />

		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="flipagent" />
		<meta property="og:locale" content="en_US" />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:site" content="@flipagent_dev" />
		<meta name="twitter:creator" content="@flipagent_dev" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="icon" href="/favicon.png" type="image/png" sizes="32x32" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

		{jsonLd && (
			<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		)}
	</head>
	<body>
		<!-- Top announcement banner — full-bleed thin strip -->
		{path === "/" && (
			<div class="banner">
				<span class="banner-text">Now backed by <span class="banner-name">Founders, Inc.</span></span>
				<span class="banner-sep">·</span>
				<a href="/dashboard/">Get early access →</a>
			</div>
		)}

		<!-- Sticky header -->
		<header class="site">
			<div class="cmw cmw-bordered header-row">
				<a href="/" class="brand">
					<img class="logo" src="/logo.png" width="72" height="20" alt="" aria-hidden="true" />
					flipagent
				</a>
				<nav class="site">
					<a href="/docs/" class={`nav-link ${path.startsWith("/docs") && !path.startsWith("/docs/api") ? "active" : ""}`}>Docs</a>
					<a href="/docs/api/" class={`nav-link ${path.startsWith("/docs/api") ? "active" : ""}`}>API</a>
					<a href="/pricing/" class={`nav-link ${path.startsWith("/pricing") ? "active" : ""}`}>Pricing</a>
				</nav>
				<div class="header-right">
					<a href="https://github.com/flipagent/flipagent" class="icon-btn" aria-label="GitHub">
						<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.6 0-12 5.4-12 12 0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.2 1.9 1.2 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6C20.6 21.8 24 17.3 24 12c0-6.6-5.4-12-12-12z"/></svg>
						<span id="gh-stars-count" data-baseline={stars ?? ""}>{stars ?? ""}</span>
					</a>
					<UserMenu client:load />
				</div>
			</div>
		</header>

		<main>
			<div class="page-frame">
				<slot />
				<div class="cmw cmw-bordered">
					<div class="section-spacer" aria-hidden="true"></div>
				</div>
			</div>
		</main>

		<footer class="site">
			<div class="page-frame">
				<div class="cmw">
					<div class="foot-grid">
						<section class="foot-col">
							<h5 class="foot-cell foot-h">Product</h5>
							<a class="foot-cell" href="/docs/">Docs</a>
							<a class="foot-cell" href="/docs/api/">API</a>
							<a class="foot-cell" href="/pricing/">Pricing</a>
							<a class="foot-cell" href="/signup/">Get a key</a>
							<a class="foot-cell" href="/docs/self-host/">Self-host</a>
						</section>

						<section class="foot-col">
							<h5 class="foot-cell foot-h">Developers</h5>
							<a class="foot-cell" href="/docs/quickstart/">Quickstart</a>
							<a class="foot-cell" href="/docs/mcp/">MCP setup</a>
							<a class="foot-cell" href="https://github.com/flipagent/flipagent">
								<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.6 0-12 5.4-12 12 0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.4-1.8-1.4-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.9 1.2 1.9 1.2 1.1 1.9 2.9 1.4 3.6 1 .1-.8.4-1.4.8-1.7-2.7-.3-5.5-1.3-5.5-6 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 6 .4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6C20.6 21.8 24 17.3 24 12c0-6.6-5.4-12-12-12z"/></svg>
								GitHub
							</a>
							<a class="foot-cell" href="https://discord.gg/PUyURdjMtv">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.317 4.37a19.79 19.79 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.74 19.74 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.1 13.1 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.009c.12.099.246.198.373.292a.077.077 0 0 1-.006.127 12.3 12.3 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.84 19.84 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.06.06 0 0 0-.031-.03zM8.02 15.331c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.974 0c-1.182 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
								Discord
							</a>
							<a class="foot-cell" href="https://x.com/flipagent_dev">
								<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
								@flipagent_dev
							</a>
						</section>

						<section class="foot-col">
							<h5 class="foot-cell foot-h">Policies</h5>
							<a class="foot-cell" href="/legal/compliance/">Compliance</a>
							<a class="foot-cell" href="/legal/privacy/">Privacy</a>
							<a class="foot-cell" href="/legal/terms/">Terms</a>
							<a class="foot-cell" href="mailto:hello@flipagent.dev">Contact</a>
							<a class="foot-cell" href="/legal/aup/">AUP</a>
						</section>
					</div>
					<div class="foot-bottom">
						<span>© 2026 FLIPAGENT</span>
						<span>HELLO@FLIPAGENT.DEV</span>
					</div>
				</div>
			</div>
		</footer>

		{/* Hydrate the GitHub star count from the visitor's own IP. Build-time
		    fetch above is unreliable on Cloudflare Pages (shared-IP rate limits
		    on api.github.com), and is also frozen until the next deploy.
		    1h localStorage cache so we don't hammer the API on every nav. */}
		<script is:inline>
			(async () => {
				const el = document.getElementById("gh-stars-count");
				if (!el) return;
				const KEY = "flipagent:gh:stars";
				const TTL_MS = 60 * 60 * 1000;
				const paint = (n) => {
					el.textContent = String(n);
				};
				try {
					const raw = localStorage.getItem(KEY);
					if (raw) {
						const cached = JSON.parse(raw);
						if (cached && typeof cached.n === "number" && Date.now() - cached.ts < TTL_MS) {
							paint(cached.n);
							return;
						}
					}
				} catch {}
				try {
					const r = await fetch("https://api.github.com/repos/flipagent/flipagent", {
						headers: { Accept: "application/vnd.github+json" },
					});
					if (!r.ok) return;
					const d = await r.json();
					if (typeof d?.stargazers_count === "number") {
						paint(d.stargazers_count);
						try {
							localStorage.setItem(KEY, JSON.stringify({ n: d.stargazers_count, ts: Date.now() }));
						} catch {}
					}
				} catch {}
			})();
		</script>
	</body>
</html>
