---
/**
 * eBay coverage map. Rendered from `src/data/coverage.ts` — the data is
 * the source of truth, this file is just the table view. Re-run
 * `node apps/docs/scripts/extract-coverage.mjs` to refresh data from a
 * legacy hand-edited copy; otherwise edit `coverage.ts` directly.
 *
 * The Setup / Tier / Phase 1 intro tables stay inline because they're
 * editorial context, not data, and never grow row-by-row.
 */
import Layout from "../../layouts/Layout.astro";
import DocsSidebar from "../../components/DocsSidebar.astro";
import { COVERAGE_SECTIONS, NATIVE_ROWS, TRADING_ROWS } from "../../data/coverage.ts";
---
<Layout title="eBay coverage · flipagent docs">
	<div class="cmw cmw-bordered">
		<div class="docs-shell">
			<DocsSidebar />
			<article class="docs-content">
				<h1>eBay coverage</h1>
				<p class="lead">
					flipagent wraps eBay's full reseller cycle — sourcing, evaluate,
					buy, list, fulfill, finance — into one <code>/v1/*</code> surface.
					This page maps every eBay endpoint we cover, what carries it, and
					where it's exposed.
				</p>

				<h2>Setup</h2>
				<p>Every endpoint needs a flipagent API key (Bearer token). The Setup column below shows the auth model for each endpoint.</p>
				<table class="api">
					<thead><tr><th>Setup</th><th>What it means</th></tr></thead>
					<tbody>
						<tr>
							<td><code>flipagent API key</code></td>
							<td>Just your flipagent Bearer token. Nothing on the eBay side — flipagent reaches eBay for public marketplace data.</td>
						</tr>
						<tr>
							<td><code>eBay OAuth</code></td>
							<td>Plus connect your eBay account once via <code>/v1/connect/ebay</code> (eBay's standard OAuth). Used for anything on your account: listings, sales, payouts, messages, returns.</td>
						</tr>
						<tr>
							<td><code>flipagent extension</code></td>
							<td>Plus install the flipagent Chrome extension and stay logged into eBay in Chrome. flipagent runs buying and package-forwarder jobs in your own session.</td>
						</tr>
					</tbody>
				</table>

				<h2>Tier</h2>
				<table class="api">
					<thead><tr><th>Tier</th><th>Exposed via</th><th>Audience</th></tr></thead>
					<tbody>
						<tr><td><strong>T1</strong></td><td>Route + SDK + MCP + Dashboard</td><td>Daily reseller flow. Sourcing, evaluate, buy, list, ship, sales.</td></tr>
						<tr><td><strong>T2</strong></td><td>Route + SDK + Dashboard</td><td>Power-user ops. Payouts, policies, promotions, ads, disputes.</td></tr>
						<tr><td><strong>T3</strong></td><td>Route + SDK</td><td>Programmatic only. Feedback, notifications, niche metadata.</td></tr>
						<tr><td><strong>T4</strong></td><td>Service wrapper only</td><td>Niche or not yet surfaced. Call site ready, no public surface today.</td></tr>
					</tbody>
				</table>

				<h2>Current focus — Phase 1</h2>
				<p>
					flipagent's goal is a hands-off reselling business an agent can run end-to-end through conversation: source, buy, receive (via forwarder), list, sell, ship, communicate, refund, analyze. Right now we're implementing and verifying the surfaces below end-to-end. Everything else on this page has wrappers in place but isn't part of the V1 contract.
				</p>
				<table class="api">
					<thead><tr><th>Phase</th><th>Surfaces in Phase 1</th></tr></thead>
					<tbody>
						<tr><td><strong>Source</strong></td><td><a href="#buy-browse">items search/sold/detail</a>, <a href="#flipagent-native">evaluate</a>, <a href="#commerce-taxonomy">categories (+ suggest, aspects)</a>, <a href="#commerce-catalog">products (EPID)</a></td></tr>
						<tr><td><strong>Buy</strong></td><td><a href="#buy-order">purchases</a> (full lifecycle), <a href="#buy-offer">bids</a> (auctions)</td></tr>
						<tr><td><strong>Receive</strong></td><td><a href="#flipagent-native">forwarder</a> (Planet Express today)</td></tr>
						<tr><td><strong>List</strong></td><td><a href="#sell-inventory">listings</a>, listings/fees, <a href="#sell-inventory">locations</a>, <a href="#sell-account">policies</a>, <a href="#commerce-media">media</a></td></tr>
						<tr><td><strong>Sell</strong></td><td><a href="#sell-fulfillment">sales</a> (list, get, ship), <a href="#sell-logistics">labels</a> (quote, buy, download)</td></tr>
						<tr><td><strong>Communicate</strong></td><td><a href="#commerce-message">messages</a>, <a href="#commerce-feedback">feedback</a>, <a href="#commerce-notification">notifications + webhooks</a>, <a href="#sell-negotiation">offers</a> (Best Offer)</td></tr>
						<tr><td><strong>Resolve</strong></td><td><a href="#post-order">disputes</a> (return, cancellation, case, inquiry, payment)</td></tr>
						<tr><td><strong>Analyze</strong></td><td><a href="#sell-finances">payouts, transactions, transfers</a>, <a href="#sell-analytics">analytics</a>, <a href="#sell-recommendation">recommendations</a></td></tr>
						<tr><td><strong>Tax</strong></td><td><a href="#sell-account">seller/sales-tax</a></td></tr>
						<tr><td><strong>Operational</strong></td><td>connect/ebay, keys, billing, me (+ overview, devices, ebay), health, capabilities, admin</td></tr>
					</tbody>
				</table>
				<p>
					Total: about 25 surfaces. Phase 1 covers everything an agent needs to drive the cycle without the user touching the eBay UI. Surfaces outside this set (translate, charity, store, marketing automation, analytics deep dives, bulk listing variants, etc.) stay wrapped but are not exposed for V1.
				</p>

				<h2 id="who-am-i">Who am I — identity + quota</h2>
				<p>
					"Me" is split across endpoints by data domain so an API-key compromise doesn't leak the human user's profile or other keys. Agents almost always want the bottom three; the dashboard cookie surface stays separate.
				</p>
				<table class="api">
					<thead><tr><th>Endpoint</th><th>Setup</th><th>Answers</th></tr></thead>
					<tbody>
						<tr>
							<td><code>GET /v1/me</code></td>
							<td>Dashboard cookie</td>
							<td>The signed-in human — email, billing status, all keys they own. Not callable with a flipagent API key (Bearer).</td>
						</tr>
						<tr>
							<td><code>GET /v1/keys/me</code></td>
							<td>flipagent API key</td>
							<td>The calling key itself — tier, quota used / remaining, period reset.</td>
						</tr>
						<tr>
							<td><code>GET /v1/connect/ebay/status</code></td>
							<td>flipagent API key</td>
							<td>Whether the calling key is bound to an eBay account; granted scopes; access-token expiry; extension pairing state.</td>
						</tr>
						<tr>
							<td><code>GET /v1/me/seller/privilege</code></td>
							<td>flipagent API key + eBay OAuth</td>
							<td>The bound eBay account's seller-side state (privilege, payments program eligibility, store subscription, etc.).</td>
						</tr>
					</tbody>
				</table>

				{COVERAGE_SECTIONS.map((s) => (
					<>
						<h2 id={s.id}>{s.title}</h2>
						<p>{s.description}</p>
						<table class="api">
							<thead><tr><th>eBay endpoint</th><th>flipagent</th><th>Setup</th><th>Tier</th></tr></thead>
							<tbody>
								{s.rows.map((r) => (
									<tr>
										<td><code>{r.ebay}</code></td>
										<td>{r.flipagent === null ? "—" : <code>{r.flipagent}</code>}</td>
										<td>{r.setup ?? s.defaultSetup}</td>
										<td>{r.tier ?? s.defaultTier}</td>
									</tr>
								))}
							</tbody>
						</table>
					</>
				))}

				<h2 id="trading-xml">Trading (XML/SOAP)</h2>
				<p>eBay's legacy SOAP API. flipagent uses it for listing CRUD on sandbox and for My eBay aggregations not exposed via REST. Requires eBay OAuth.</p>
				<table class="api">
					<thead><tr><th>Trading call</th><th>flipagent</th><th>Tier</th></tr></thead>
					<tbody>
						{TRADING_ROWS.map((r) => (
							<tr>
								<td><code>{r.trading}</code></td>
								<td><code>{r.flipagent}</code></td>
								<td>{r.tier}</td>
							</tr>
						))}
					</tbody>
				</table>

				<h2 id="flipagent-native">flipagent-native</h2>
				<p>Compound endpoints unique to flipagent. They orchestrate one or more eBay surfaces, run server-side compute, and return our shape.</p>
				<table class="api">
					<thead><tr><th>flipagent</th><th>What it composes</th><th>Tier</th></tr></thead>
					<tbody>
						{NATIVE_ROWS.map((r) => (
							<tr>
								<td><code>{r.flipagent}</code></td>
								<td>{r.composes}</td>
								<td>{r.tier}</td>
							</tr>
						))}
					</tbody>
				</table>
			</article>
		</div>
	</div>
</Layout>
