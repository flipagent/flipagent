---
/**
 * /embed/next-action — onboarding / remediation surface for tool errors
 * that carry a `next_action` (no eBay account, missing extension, …).
 * Same iframe transport as the other /embed/* surfaces.
 */
import "../../styles/global.css";
import "../../components/playground/Playground.css";
import { EmbedNextAction } from "../../components/embed/EmbedNextAction";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>flipagent · next action</title>
		<style>
			:root {
				color-scheme: light;
			}
			html,
			body {
				margin: 0;
				padding: 0;
				background: transparent;
				overflow: hidden;
			}
			body {
				font-family: "Geist", system-ui, sans-serif;
				color: var(--text);
				font-size: 13px;
				line-height: 1.45;
			}
		</style>
	</head>
	<body>
		<EmbedNextAction client:load />
	</body>
</html>
