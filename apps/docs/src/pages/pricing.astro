---
import Layout from "../layouts/Layout.astro";
import PricingTiers from "../components/PricingTiers.astro";
import Faq from "../components/Faq.tsx";
import Reveal from "../components/Reveal.tsx";
import AgentChatPriceRow from "../components/AgentChatPriceRow.tsx";
import "../components/PricingRow.css";
---
<Layout
	title="Pricing · flipagent"
	description="Usage-based pricing for the flipagent API. Free tier to start, then pay only for what your AI agent does — searches, evaluations, listings, orders."
>
	<section class="hero">
		<div class="cmw cmw-bordered" style="padding-top:64px; padding-bottom:48px;">
			<h1>Start free. Pay <span class="accent">when you scale</span>.</h1>
			<p class="lead">
				Pay only for what we run on our infrastructure. Start free, scale as you grow.
			</p>
		</div>
	</section>

	<section class="pricing-stack">
		<div class="cmw cmw-bordered">
			<PricingTiers />

			<div class="section-spacer" aria-hidden="true"></div>

			<!--
				No <Reveal> wrapper here: <AgentChatPriceRow client:load /> needs
				to be its own island, but Astro doesn't hydrate islands nested
				inside another React island (Reveal is `motion.div` from
				motion/react, which becomes a React island on `client:visible`).
				The select trigger would render but its onClick wouldn't fire.
			-->
			<div class="pricing-row" id="api-credits">
				<div class="pricing-row-head">
					<h2>API <span class="accent">credits</span></h2>
					<p>Marketplace data, listing evaluations, and AI agent chat cost credits. Anything that runs on your own connected eBay account is free.</p>
				</div>
				<div class="pricing-row-body">
					<div class="pricing-row-item">
						<div class="pricing-row-item-text">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<circle cx="10.5" cy="10.5" r="6.5"></circle>
								<path d="m20 20-4.5-4.5"></path>
							</svg>
							<div>
								<span>Search &amp; sourcing</span>
								<span>Keyword search, category browse, item lookup.</span>
							</div>
						</div>
						<div class="pricing-row-item-value"><span class="num">1</span><span class="unit">/ call</span></div>
					</div>
					<div class="pricing-row-item">
						<div class="pricing-row-item-text">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M4 14a8 8 0 0 1 16 0"></path>
								<path d="M12 14l3-4"></path>
								<circle cx="12" cy="14" r="0.9" fill="currentColor"></circle>
							</svg>
							<div>
								<span>Evaluate</span>
								<span>Score a listing for profit, sell-through, and risk. One call, full verdict.</span>
							</div>
						</div>
						<div class="pricing-row-item-value"><span class="num">80</span><span class="unit">/ call</span></div>
					</div>
					<AgentChatPriceRow client:load />
					<div class="pricing-row-item">
						<div class="pricing-row-item-text">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<rect x="3" y="4" width="18" height="16" rx="2"></rect>
								<path d="M3 9h18"></path>
								<circle cx="6.5" cy="6.5" r="0.4" fill="currentColor"></circle>
								<circle cx="9" cy="6.5" r="0.4" fill="currentColor"></circle>
							</svg>
							<div>
								<span>Account ops</span>
								<span>Sell, fulfill, message, ship, and buy on your own account.</span>
							</div>
						</div>
						<div class="pricing-row-item-value"><span class="num">Free</span></div>
					</div>
				</div>
			</div>

			<div class="section-spacer" aria-hidden="true"></div>

			<Reveal client:visible>
				<div class="pricing-row">
					<div class="pricing-row-head">
						<h2>Beyond <span class="accent">credits</span></h2>
						<p>Two paths past the public tiers.</p>
					</div>
					<div class="pricing-row-body">
						<div class="pricing-row-item">
							<div class="pricing-row-item-text">
								<div>
									<span>Enterprise</span>
									<span>Custom credit volume, dedicated infra, SLA, white-label.</span>
								</div>
							</div>
							<a href="mailto:hello@flipagent.dev" class="btn">Contact us <span class="arrow">→</span></a>
						</div>
						<div class="pricing-row-item">
							<div class="pricing-row-item-text">
								<div>
									<span>Self-host</span>
									<span>Open source. Run it on your own infrastructure.</span>
								</div>
							</div>
							<a href="https://github.com/flipagent/flipagent" class="btn">View on GitHub <span class="arrow">→</span></a>
						</div>
						<div class="pricing-row-item">
							<div class="pricing-row-item-text">
								<div>
									<span>Community</span>
									<span>Discord for questions, bugs, and build talk.</span>
								</div>
							</div>
							<a href="https://discord.gg/PUyURdjMtv" class="btn">Join Discord <span class="arrow">→</span></a>
						</div>
					</div>
				</div>
			</Reveal>

			<div class="section-spacer" aria-hidden="true"></div>

			<Reveal client:visible delay={0.05}>
				<Faq labels={["Billing"]} client:visible />
			</Reveal>
		</div>
	</section>
</Layout>
