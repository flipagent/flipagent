---
type Tier = {
	name: string;
	tagline: string;
	calls: string;
	price: string;
	per?: string;
	cta: { label: string; href: string; heat?: boolean };
	badge?: string;
	features: string[];
};

const tiers: Tier[] = [
	{
		name: "Free",
		tagline: "Real product test. No card, no eBay developer account.",
		calls: "1,000 credits (one-time)",
		price: "$0",
		per: "/forever",
		cta: { label: "Get started", href: "/signup/" },
		// Concrete sample-mix translations of the credit budget so the
		// number "1,000" gains shape. Each line uses one cost element
		// from the menu (search 1, evaluate 80, mini chat 5).
		features: ["1,000 credits", "12 evaluations", "Basic agent (mini + Flash)", "All sell-side ops"],
	},
	{
		name: "Hobby",
		tagline: "Side projects and personal flipping. Just enough headroom.",
		calls: "3,000 credits / month",
		price: "$19",
		per: "/mo",
		cta: { label: "Start free", href: "/signup/" },
		// Top-up rate per 1k so the per-credit price is concrete and
		// trivially scalable in your head ("3k extras? 3 × $9.50 = $28.50").
		// Sits in the feature checklist because it's a *capability*
		// the tier unlocks, not part of the base allotment.
		features: [
			"3,000 credits / month",
			"~37 evaluations",
			"All agent models (mini, Flash, Sonnet, gpt-5.5)",
			"$9.50 / 1k extra credits",
			"Email support",
		],
	},
	{
		name: "Standard",
		tagline: "Production agents and full-time resellers at real volume.",
		calls: "25,000 credits / month",
		price: "$99",
		per: "/mo",
		badge: "Most popular",
		cta: { label: "Start free", href: "/signup/", heat: true },
		features: [
			"25,000 credits / month",
			"~312 evaluations",
			"All agent models (mini, Flash, Sonnet, gpt-5.5)",
			"$6 / 1k extra credits",
			"Priority support",
		],
	},
	{
		name: "Growth",
		tagline: "Automation fleets and businesses scanning the market 24/7.",
		calls: "120,000 credits / month",
		price: "$399",
		per: "/mo",
		cta: { label: "Start free", href: "/signup/" },
		features: [
			"120,000 credits / month",
			"~1,500 evaluations",
			"All agent models (mini, Flash, Sonnet, gpt-5.5)",
			"$5 / 1k extra credits",
		],
	},
];
---
<div class="tiers">
	{tiers.map((t) => (
		<div class="tier">
			<div class="tier-head">
				<div class="name-row">
					<span class="name">{t.name}</span>
					{t.badge && <span class="badge">{t.badge}</span>}
				</div>
				<div class="tagline">{t.tagline}</div>
				<div class="calls">{t.calls}</div>
			</div>
			<div class="tier-buy">
				<div class="price">
					{t.price}
					{t.per && <span class="per">{t.per}</span>}
				</div>
				<a href={t.cta.href} class={`btn block${t.cta.heat ? " heat" : ""}`}>{t.cta.label}</a>
			</div>
			<div class="tier-features">
				<ul>
					{t.features.map((f) => <li>{f}</li>)}
				</ul>
			</div>
		</div>
	))}
</div>
