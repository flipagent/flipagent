---
type Tier = {
	name: string;
	tagline: string;
	calls: string;
	price: string;
	per?: string;
	cta: { label: string; href: string; heat?: boolean };
	badge?: string;
	features: string[];
};

const tiers: Tier[] = [
	{
		name: "Free",
		tagline: "Kick the tires. No card, no eBay developer account.",
		calls: "500 credits (one-time)",
		price: "$0",
		per: "/forever",
		cta: { label: "Get started", href: "/signup/" },
		features: ["500 searches", "10 evaluations", "10 calls/min"],
	},
	{
		name: "Hobby",
		tagline: "Side projects and personal flipping. Just enough headroom.",
		calls: "3,000 credits / month",
		price: "$19",
		per: "/mo",
		cta: { label: "Start free", href: "/signup/" },
		// Top-up rate per 1k so the per-credit price is concrete +
		// trivially scalable in your head ("25k extras? 25 × $3 = $75").
		// Sits in the feature checklist because it's a *capability*
		// the tier unlocks, not part of the base allotment.
		features: [
			"3,000 searches",
			"60 evaluations",
			"30 calls/min",
			"$3 / 1k extra credits",
			"Email support",
		],
	},
	{
		name: "Standard",
		tagline: "Production agents and full-time resellers at real volume.",
		calls: "100,000 credits / month",
		price: "$99",
		per: "/mo",
		badge: "Most popular",
		cta: { label: "Start free", href: "/signup/", heat: true },
		features: [
			"100,000 searches",
			"2,000 evaluations",
			"120 calls/min",
			"$2 / 1k extra credits",
			"Priority support",
		],
	},
	{
		name: "Growth",
		tagline: "Automation fleets and businesses scanning the market 24/7.",
		calls: "500,000 credits / month",
		price: "$399",
		per: "/mo",
		cta: { label: "Start free", href: "/signup/" },
		features: [
			"500,000 searches",
			"10,000 evaluations",
			"600 calls/min",
			"$1.50 / 1k extra credits",
		],
	},
];
---
<div class="tiers">
	{tiers.map((t) => (
		<div class="tier">
			<div class="tier-head">
				<div class="name-row">
					<span class="name">{t.name}</span>
					{t.badge && <span class="badge">{t.badge}</span>}
				</div>
				<div class="tagline">{t.tagline}</div>
				<div class="calls">{t.calls}</div>
			</div>
			<div class="tier-buy">
				<div class="price">
					{t.price}
					{t.per && <span class="per">{t.per}</span>}
				</div>
				<a href={t.cta.href} class={`btn block${t.cta.heat ? " heat" : ""}`}>{t.cta.label}</a>
			</div>
			<div class="tier-features">
				<ul>
					{t.features.map((f) => <li>{f}</li>)}
				</ul>
			</div>
		</div>
	))}
</div>
