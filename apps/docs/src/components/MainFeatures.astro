---
import EvalChartDemo from "./EvalChartDemo.tsx";

// MainFeatures — three cards in an asymmetric grid:
//   ┌────────── lead (full row) ──────────┐
//   │  Card 1: Sourcing  (live)            │
//   ├──────────────────┬──────────────────┤
//   │  Card 2: Evaluate│  Card 3: Ops     │
//   │     (live)       │  (coming soon)   │
//   └──────────────────┴──────────────────┘

// Card 1 — three illustrative sourcing scenes. Each scene is a
// natural-language query (left) paired with abstracted result rows
// (right): a thumbnail block, a title bar of varying width, and a
// brand-orange margin chip. The whole stage cycles via a single
// CSS animation: 9s loop, three 3s phases, opacity-cross-faded.
// Width and margin values are illustrative only.
const hunts = [
	{
		query: "Auctions ending in 10 min",
		results: [
			{ w: 72, m: "+$36" },
			{ w: 55, m: "+$22" },
			{ w: 84, m: "+$48" },
		],
	},
	{
		query: "40% below 30-day median",
		results: [
			{ w: 66, m: "+$42" },
			{ w: 88, m: "+$56" },
			{ w: 60, m: "+$31" },
		],
	},
	{
		query: "Watches with ≥3 bids, no reserve",
		results: [
			{ w: 76, m: "+$24" },
			{ w: 50, m: "+$19" },
			{ w: 70, m: "+$33" },
		],
	},
];

// Card 2's chart is the real `PriceHistogram` from the playground —
// see `EvalChartDemo.tsx` for the comp data. Marketing visual stays
// identical to the in-product evaluate result so users see the same
// chart on landing as they will in the dashboard.
---

<section class="main-features">
	<!-- Card 1 — Sourcing / natural-language hunts (full width) -->
	<article class="main-feature main-feature--lead" aria-label="Sourcing">
		<header class="feat-text">
			<div class="feat-meta">
				<span class="feat-meta-icon" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="11" cy="11" r="8"/>
						<line x1="21" y1="21" x2="16.65" y2="16.65"/>
					</svg>
				</span>
				<span class="feat-meta-num">#01</span>
				<span class="feat-meta-label">Sourcing</span>
			</div>
			<p class="feat-lede">
				<strong>You describe. The agent finds.</strong>
				Plain English, any criteria.
			</p>
		</header>
		<div class="feat-viz feat-viz-hunts" aria-hidden="true">
			<div class="hunt-stage">
				<div class="hunt-prompts">
					<span class="hunt-prefix" aria-hidden="true">&gt;</span>
					<span class="hunt-text-stack">
						{hunts.map((h, i) => (
							<span class="hunt-text-item" style={`--d: ${i * 4}s`}>
								<span class="hunt-text">{h.query}</span>
								<span class="hunt-tail" aria-hidden="true">
									<span class="hunt-cursor"></span>
									<span class="hunt-spinner"></span>
								</span>
							</span>
						))}
					</span>
				</div>
				<div class="hunt-results-stack">
					{hunts.map((h, i) => (
						<ul class="hunt-results" style={`--d: ${i * 4}s`}>
							{h.results.map((r) => (
								<li class="hunt-result">
									<span class="hunt-thumb"></span>
									<span class="hunt-bar-wrap">
										<span class="hunt-bar" style={`width: ${r.w}%`}></span>
									</span>
									<span class="hunt-margin">{r.m}</span>
								</li>
							))}
						</ul>
					))}
				</div>
			</div>
		</div>
	</article>

	<!-- Card 2 — Evaluate / report on a single listing -->
	<article class="main-feature" aria-label="Evaluate">
		<header class="feat-text feat-text--col">
			<div class="feat-meta">
				<span class="feat-meta-icon" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<polyline points="3 17 9 11 13 15 21 7"/>
						<polyline points="14 7 21 7 21 14"/>
					</svg>
				</span>
				<span class="feat-meta-num">#02</span>
				<span class="feat-meta-label">Evaluate</span>
			</div>
			<p class="feat-lede">
				<strong>Evaluate any listing before you bid.</strong>
				See what it actually sold for, where it sits in the band, and the resale exit math.
			</p>
		</header>
		<div class="feat-viz feat-viz-distribution">
			<EvalChartDemo client:visible />
		</div>
	</article>

	<!-- Card 3 — Operations / forwarder route (coming soon) -->
	<article class="main-feature main-feature--soon" aria-label="Operations — coming soon">
		<header class="feat-text feat-text--col">
			<div class="feat-meta">
				<span class="feat-meta-icon" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
						<polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
						<line x1="12" y1="22.08" x2="12" y2="12"/>
					</svg>
				</span>
				<span class="feat-meta-num">#03</span>
				<span class="feat-meta-label">Operations</span>
				<span class="feat-meta-soon">Coming soon</span>
			</div>
			<p class="feat-lede">
				<strong>Hands off the boxes.</strong>
				A forwarder receives, repacks, and dispatches every order.
			</p>
		</header>
		<div class="feat-viz feat-viz-ops" aria-hidden="true">
			<div class="route">
				<div class="route-track">
					<div class="route-stop">
						<span class="route-dot"></span>
						<span class="route-stop-label">Seller</span>
						<span class="route-stop-loc">Cleveland, OH</span>
					</div>
					<div class="route-line"><span class="route-pkg"></span></div>
					<div class="route-stop">
						<span class="route-dot route-dot--brand"></span>
						<span class="route-stop-label">Forwarder</span>
						<span class="route-stop-loc">Wilmington, DE</span>
					</div>
					<div class="route-line"><span class="route-pkg"></span></div>
					<div class="route-stop">
						<span class="route-dot"></span>
						<span class="route-stop-label">Buyer</span>
						<span class="route-stop-loc">Phoenix, AZ</span>
					</div>
				</div>
			</div>
		</div>
	</article>
</section>
