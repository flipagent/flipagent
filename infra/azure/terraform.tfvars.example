# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

environment  = "prod"
location     = "eastus2"
postgres_sku = "B_Standard_B1ms"

# Custom domain. Leave empty to skip; bind later.
# custom_domain = "api.flipagent.dev"

# First-creation image for the api + worker container apps. Both
# resources have `lifecycle ignore_changes = [image]`, so after the
# first revision the CI workflow rolls them to a specific git-sha tag
# on every push — this value only matters at provision time. Use
# `:latest` so a fresh apply always pulls the most recent CI build.
# api_image = "<acr-name>.azurecr.io/api:latest"

# Managed scraper vendor for eBay reads. Two wired vendors:
#   `oxylabs` — POST URL → rendered HTML → parsed by @flipagent/ebay-scraper.
#               Auth: scraper_api_username / scraper_api_password.
#   `sprd`    — peer flipagent-shape API at api-dev.sprd.app. Returns
#               already-parsed Browse/Catalog JSON; the four scrape*()
#               entry points short-circuit our HTML→parser pipe. Auth:
#               sprd_api_key (`x-api-key`); base via sprd_api_url.
# Leaving the vendor's auth fields empty disables managed scraping —
# fine for low-volume self-host (point EBAY_*_SOURCE at `bridge` or
# `rest`), but expect to hit eBay's bot wall fast on direct egress.
# scraper_api_vendor   = "oxylabs"
# scraper_api_username = "USER"
# scraper_api_password = "PASS"
# sprd_api_url         = "https://api-dev.sprd.app"
# sprd_api_key         = "..."

# Stripe — leave empty to ship with /v1/billing/* returning 503.
# stripe_secret_key     = "sk_live_..."
# stripe_webhook_secret = "whsec_..."
# stripe_price_hobby    = "price_..."
# stripe_price_standard = "price_..."
# stripe_price_growth   = "price_..."

# eBay OAuth — leave empty to ship with /v1/connect/ebay + every sell-side
# route (/v1/listings, /v1/sales, /v1/payouts, /v1/transactions, /v1/policies,
# /v1/disputes, …) returning 503 not_configured. Register the keyset + RuName
# at developer.ebay.com.
# Sandbox: swap api.ebay.com → api.sandbox.ebay.com and auth.ebay.com → auth.sandbox.ebay.com.
# ebay_client_id          = "YourApp-PRD-..."
# ebay_client_secret      = "PRD-..."
# ebay_ru_name            = "Your_App-RuName"
# ebay_base_url           = "https://api.ebay.com"
# ebay_auth_url           = "https://auth.ebay.com"
# ebay_order_api_approved = false   # flip to true ONLY after eBay grants approval
# ebay_insights_approved  = false   # flip to true ONLY after Marketplace Insights approval
# ebay_catalog_approved   = false   # flip to true ONLY after Commerce Catalog approval

# Per-listing observation archive — hosted-only feature. When true, every
# /v1/items/* response writes one row to listing_observations for
# historical depth + cross-user reputation. Self-host typically leaves
# off (default).
# observation_enabled = false

# Operator allow-list. Comma-separated emails auto-promoted to role=admin
# on next session. Admins get the /v1/admin/* surface and the /admin
# dashboard page. Empty = no admins.
# admin_emails = "you@flipagent.dev,ops@flipagent.dev"

# AES-256-GCM symmetric key (base64) used to encrypt issued API key
# plaintext at rest. REQUIRED in production for the dashboard's
# "reveal key" feature; sha256 hash auth still works without it.
# Generate once with `openssl rand -base64 32`. Stored in Key Vault.
# AES-256-GCM symmetric key for encrypting issued API key plaintext at
# rest. Required in production for the dashboard's "reveal key" flow;
# without it the column stays null on new keys and reveal returns 503
# (sha256 hash auth still works). Generate with `openssl rand -base64 32`.
# Migrate to a Key Vault reference when rotation cadence becomes
# operational.
# keys_encryption_key = "..."

# Better-Auth + dashboard sign-in. Leave empty to ship with /v1/me/* + /api/auth/*
# returning 503. APP_URL is the dashboard origin; BETTER_AUTH_URL is this api's
# external URL (must match GitHub/Google OAuth callback URL).
# better_auth_secret   = "..."   # openssl rand -base64 32
# app_url              = "https://flipagent.dev"
# better_auth_url      = "https://api.flipagent.dev"
# github_client_id     = ""
# github_client_secret = ""
# google_client_id     = ""
# google_client_secret = ""

# Email (Resend) — required for password reset.
# resend_api_key = "re_..."
# email_from     = "flipagent <noreply@flipagent.dev>"

# eBay Trading Platform Notifications + per-route source toggles. DevID is the
# third value on the eBay Application Keys page. NOTIFY_URL must be HTTPS-reachable
# from eBay servers (e.g. https://api.flipagent.dev/v1/notifications/ebay/inbound).
# Source toggles pick rest (Browse) | scrape | bridge per resource.
# ebay_dev_id          = "00000000-0000-0000-0000-000000000000"
# ebay_notify_url      = "https://api.flipagent.dev/v1/notifications/ebay/inbound"
# ebay_listings_source = "rest"
# ebay_detail_source   = "rest"
# ebay_sold_source     = "scrape"

# LLM provider for the same-product matcher used internally by
# /v1/evaluate. Pick one of anthropic | openai | google.
# Empty `llm_provider` falls back to the first key set
# (anthropic → openai → google). Without any key, the composite
# endpoint falls back to the unfiltered sold + active pools; every
# other route still works.
# llm_provider      = "google"
# anthropic_api_key = "sk-ant-..."
# anthropic_model   = "claude-haiku-4-5"
# openai_api_key    = "sk-..."
# openai_model      = "gpt-5.4-mini"
# google_api_key    = "..."
# google_model      = "gemini-2.5-flash"

# Agent surface (`/v1/agent/chat`) + Streamable HTTP MCP (`/mcp`).
# Reuses `openai_api_key` above. `agent_openai_model` is the default +
# Free-tier-locked model; paid-tier callers can opt up to gpt-5.5 per
# request. Without `mcp_public_url` the agent still chats but cannot
# call tools — set it to this api's external `/mcp` endpoint so OpenAI's
# Responses API can reach the tool catalog.
# agent_openai_model = "gpt-5.4-mini"
# mcp_public_url     = "https://api.flipagent.dev/mcp"
